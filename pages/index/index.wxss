/* Hero area - deep green gradient */
.home-hero {
  background: linear-gradient(160deg, #0d3b1f 0%, #0f4425 40%, #1a6b3c 100%);
  padding: 0 0 60rpx;
  position: relative;
  overflow: hidden;
}

/* Decorative wind characters */
.hero-deco {
  position: absolute;
  top: 80rpx;
  right: -20rpx;
  z-index: 0;
}

.deco-text {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 160rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.03);
  letter-spacing: 24rpx;
  writing-mode: vertical-rl;
  line-height: 1.2;
}

/* Logo */
.home-logo {
  text-align: center;
  padding: 72rpx 0 48rpx;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.kanji-box {
  width: 144rpx;
  height: 144rpx;
  border: 4rpx solid rgba(255,255,255,0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  margin-bottom: 32rpx;
}

.kanji {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 72rpx;
  font-weight: 900;
  color: #fff;
}

.home-title {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.home-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
  font-weight: 300;
}

/* Menu */
.home-menu {
  padding: 0 40rpx;
  position: relative;
  z-index: 1;
}

.menu-card {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(28,25,23,0.08), 0 2rpx 4rpx rgba(28,25,23,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  position: relative;
}

.menu-item:active {
  background: #fafaf9;
}

.menu-item + .menu-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 128rpx;
  right: 32rpx;
  height: 1rpx;
  background: #f5f5f4;
}

/* Icon boxes */
.menu-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon .icon-text {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.menu-icon.calc {
  background: linear-gradient(135deg, #1a6b3c, #2da660);
}

.menu-icon.game {
  background: linear-gradient(135deg, #d97706, #f59e0b);
}

.menu-icon.ref {
  background: linear-gradient(135deg, #6366f1, #818cf8);
}

.menu-icon.hist {
  background: linear-gradient(135deg, #78716c, #a8a29e);
}

/* Menu text */
.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #a8a29e;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d6d3d1;
  flex-shrink: 0;
}

/* Footer */
.home-footer {
  text-align: center;
  padding: 48rpx 40rpx 40rpx;
  background: #f7f5f0;
}

.rule-tag {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 28rpx;
  background: rgba(26,107,60,0.06);
  border-radius: 200rpx;
}

.tag-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2da660;
}

.tag-text {
  font-size: 22rpx;
  color: #1a6b3c;
  font-weight: 500;
}
