<view class="home-hero">
  <!-- Decorative wind characters -->
  <view class="hero-deco">
    <text class="deco-text">東南西北</text>
  </view>

  <!-- Logo area -->
  <view class="home-logo">
    <view class="kanji-box">
      <text class="kanji">雀</text>
    </view>
    <text class="home-title">日麻计分助手</text>
    <text class="home-subtitle">符数 · 番数 · 点数 一键计算</text>
  </view>

  <!-- Menu card -->
  <view class="home-menu">
    <view class="menu-card">
      <view class="menu-item" bindtap="goCalculator">
        <view class="menu-icon calc">
          <text class="icon-text">計</text>
        </view>
        <view class="menu-info">
          <text class="menu-name">快速计分</text>
          <text class="menu-desc">输入手牌，自动计算符番点数</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goGameSetup">
        <view class="menu-icon game">
          <text class="icon-text">局</text>
        </view>
        <view class="menu-info">
          <text class="menu-name">对局管理</text>
          <text class="menu-desc">四人记分板，自动结算顺位马</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goReference">
        <view class="menu-icon ref">
          <text class="icon-text">役</text>
        </view>
        <view class="menu-info">
          <text class="menu-name">役种速查</text>
          <text class="menu-desc">全役种参考，含番数与成立条件</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goHistory">
        <view class="menu-icon hist">
          <text class="icon-text">史</text>
        </view>
        <view class="menu-info">
          <text class="menu-name">历史对局</text>
          <text class="menu-desc">查看往期对局记录与结算</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>

<!-- Footer -->
<view class="home-footer">
  <view class="rule-tag">
    <view class="tag-dot"></view>
    <text class="tag-text">参考规则：雀魂 Majsoul</text>
  </view>
</view>
