<view class="container">
  <view class="logo-area">
    <text class="logo-text">雀</text>
    <text class="title">日麻计分助手</text>
    <text class="subtitle">符数·番数·点数 一键计算</text>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goCalculator">
      <text class="menu-icon-text">计</text>
      <view class="menu-info">
        <text class="menu-title">快速计分</text>
        <text class="menu-desc">输入手牌，自动计算符番点数</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goGameSetup">
      <text class="menu-icon-text">局</text>
      <view class="menu-info">
        <text class="menu-title">对局管理</text>
        <text class="menu-desc">四人记分板，自动结算顺位马</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goReference">
      <text class="menu-icon-text">役</text>
      <view class="menu-info">
        <text class="menu-title">役种速查</text>
        <text class="menu-desc">全役种参考，含番数与成立条件</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon-text">史</text>
      <view class="menu-info">
        <text class="menu-title">历史对局</text>
        <text class="menu-desc">查看往期对局记录与结算</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">参考规则：雀魂 Majsoul</text>
  </view>
</view>
