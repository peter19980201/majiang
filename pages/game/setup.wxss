.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f5f0;
}

.section {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.section-title {
  font-size: 22rpx;
  color: #a8a29e;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.seg-ctrl {
  display: flex;
  background: #fafaf9;
  border-radius: 16rpx;
  padding: 6rpx;
}

.seg {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 12rpx;
  color: #78716c;
  font-weight: 500;
}

.seg.active {
  background: #1a6b3c;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.setting-row + .setting-row {
  border-top: 2rpx solid #fafaf9;
}

.setting-label {
  font-size: 28rpx;
  color: #44403c;
  font-weight: 500;
}

.stepper {
  display: flex;
  align-items: center;
  background: #fafaf9;
  border-radius: 16rpx;
  overflow: hidden;
}

.step-btn {
  width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #78716c;
}

.step-btn:active { background: #f5f5f4; }

.step-val {
  min-width: 120rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  background: #fff;
  height: 56rpx;
  line-height: 56rpx;
}

.uma-grid {
  display: flex;
  gap: 12rpx;
}

.uma-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 18rpx 0;
  border-radius: 16rpx;
  background: #fafaf9;
  color: #78716c;
  font-weight: 500;
  transition: all 0.2s;
}

.uma-btn.active {
  background: #1a6b3c;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

.player-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-wind {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a6b3c;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #eefbf2;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.player-input {
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 24rpx;
  background: #fdfcfb;
  border-radius: 16rpx;
  border: 3rpx solid #f5f5f4;
  color: #292524;
  transition: all 0.2s;
}

.start-btn {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(26,107,60,0.35);
}

.start-btn:active { opacity: 0.9; }
