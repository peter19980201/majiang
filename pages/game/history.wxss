.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f0efe8;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 26rpx;
  color: #888;
}

.clear-all {
  font-size: 24rpx;
  color: #e53935;
  padding: 4rpx 16rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-info {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.card-date {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.card-type {
  font-size: 22rpx;
  background: #e8f5e9;
  color: #1a6b3c;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.card-abandoned {
  font-size: 20rpx;
  background: #fff3e0;
  color: #e65100;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-delete {
  font-size: 22rpx;
  color: #e53935;
  padding: 4rpx 12rpx;
}

.card-arrow {
  font-size: 24rpx;
  color: #999;
}

.rank-row {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.rank-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.rank-num {
  font-size: 20rpx;
  color: #999;
}

.rank-name {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
}

.rank-pt {
  font-size: 24rpx;
  font-weight: bold;
}

.positive { color: #1a6b3c; }
.negative { color: #c62828; }

.card-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-section {
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.round-item {
  display: flex;
  gap: 10rpx;
  align-items: baseline;
  padding: 4rpx 0;
}

.rd-round {
  font-size: 22rpx;
  color: #aaa;
  white-space: nowrap;
}

.rd-desc {
  font-size: 24rpx;
  color: #333;
}

.settle-row {
  padding: 6rpx 0;
}

.settle-name {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.settle-info {
  font-size: 22rpx;
  color: #888;
  display: block;
}

.delete-btn {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #e53935;
  padding: 12rpx 0;
  margin-top: 8rpx;
}

/* 进行中对局 */
.current-game {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 3rpx solid #e65100;
}

.current-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.current-badge {
  font-size: 22rpx;
  background: #e65100;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: bold;
}

.current-date {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.current-type {
  font-size: 22rpx;
  background: #e8f5e9;
  color: #1a6b3c;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.current-info {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.current-round {
  font-size: 28rpx;
  color: #1a6b3c;
  font-weight: bold;
}

.current-supply {
  font-size: 24rpx;
  color: #e65100;
}

.current-players {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.cp-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  background: #f8f8f5;
  border-radius: 8rpx;
  padding: 8rpx 0;
}

.cp-name {
  font-size: 22rpx;
  color: #666;
}

.cp-pts {
  font-size: 26rpx;
  font-weight: bold;
}

.current-actions {
  display: flex;
  gap: 12rpx;
}

.current-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.current-btn.resume {
  background: linear-gradient(135deg, #1a6b3c, #2e7d32);
  color: #fff;
}

.current-btn.abandon {
  background: #f5f5f5;
  color: #999;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}
