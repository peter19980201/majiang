.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #f7f5f0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 26rpx;
  color: #a8a29e;
  font-weight: 500;
}

.clear-all {
  font-size: 24rpx;
  color: #dc2626;
  padding: 4rpx 16rpx;
  font-weight: 500;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* History cards */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
  border: 2rpx solid #fafaf9;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-info {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.card-date {
  font-size: 28rpx;
  color: #292524;
  font-weight: 600;
}

.card-type {
  font-size: 22rpx;
  background: #dcf5e5;
  color: #1a6b3c;
  padding: 6rpx 14rpx;
  border-radius: 200rpx;
  font-weight: 600;
}

.card-abandoned {
  font-size: 20rpx;
  background: #fef3c7;
  color: #b45309;
  padding: 4rpx 12rpx;
  border-radius: 200rpx;
  font-weight: 500;
}

.card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-delete {
  font-size: 22rpx;
  color: #dc2626;
  padding: 4rpx 12rpx;
}

.card-arrow {
  font-size: 24rpx;
  color: #d6d3d1;
}

/* Ranking row */
.rank-row {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.rank-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  background: #fdfcfb;
  border-radius: 12rpx;
  padding: 10rpx 0;
}

.rank-num {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 20rpx;
  color: #d6d3d1;
  font-weight: 700;
}

.rank-name {
  font-size: 24rpx;
  color: #57534e;
  font-weight: 500;
}

.rank-pt {
  font-size: 24rpx;
  font-weight: 700;
}

.positive { color: #1a6b3c; }
.negative { color: #dc2626; }

/* Expanded detail */
.card-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #fafaf9;
  background: #fdfcfb;
  margin: 16rpx -28rpx 0;
  padding: 20rpx 28rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.detail-section {
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 22rpx;
  color: #a8a29e;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.round-item {
  display: flex;
  gap: 10rpx;
  align-items: baseline;
  padding: 6rpx 0;
}

.rd-round {
  font-size: 22rpx;
  color: #a8a29e;
  white-space: nowrap;
  font-weight: 600;
}

.rd-desc {
  font-size: 24rpx;
  color: #44403c;
}

.settle-row {
  padding: 6rpx 0;
}

.settle-name {
  font-size: 24rpx;
  color: #292524;
  font-weight: 600;
  display: block;
}

.settle-info {
  font-size: 22rpx;
  color: #a8a29e;
  display: block;
}

.delete-btn {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #dc2626;
  padding: 12rpx 0;
  margin-top: 8rpx;
}

/* Active game card */
.current-game {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #f59e0b;
  box-shadow: 0 2rpx 8rpx rgba(28,25,23,0.06), 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.current-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.current-badge {
  font-size: 22rpx;
  background: #f59e0b;
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 200rpx;
  font-weight: 600;
}

.current-date {
  font-size: 26rpx;
  color: #292524;
  font-weight: 600;
}

.current-type {
  font-size: 22rpx;
  background: #dcf5e5;
  color: #1a6b3c;
  padding: 6rpx 14rpx;
  border-radius: 200rpx;
  font-weight: 600;
}

.current-info {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.current-round {
  font-size: 28rpx;
  color: #1a6b3c;
  font-weight: bold;
}

.current-supply {
  font-size: 24rpx;
  color: #d97706;
}

.current-players {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.cp-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  background: #fdfcfb;
  border-radius: 16rpx;
  padding: 12rpx 0;
}

.cp-name {
  font-size: 22rpx;
  color: #78716c;
}

.cp-pts {
  font-size: 26rpx;
  font-weight: bold;
}

.current-actions {
  display: flex;
  gap: 12rpx;
}

.current-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.current-btn.resume {
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

.current-btn.abandon {
  background: #fafaf9;
  color: #a8a29e;
}

/* Empty state */
.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #d6d3d1;
}
