.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f5f0;
}

/* Round info bar */
.round-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #0d3b1f, #1a6b3c);
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.round-bar::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%);
  border-radius: 50%;
}

.round-label {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
}

.honba-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  position: relative;
}

.riichi-label {
  font-size: 24rpx;
  color: #fbbf24;
  position: relative;
}

.game-over-badge {
  font-size: 24rpx;
  background: #d97706;
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 200rpx;
  margin-left: auto;
  font-weight: 600;
  position: relative;
}

/* Players grid */
.players-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.player-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
  border: 4rpx solid transparent;
}

.player-card.dealer {
  border-color: #f59e0b;
}

.player-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.player-wind-badge {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a6b3c;
}

.dealer-mark {
  font-size: 20rpx;
  background: #f59e0b;
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 200rpx;
  font-weight: 600;
}

.player-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #57534e;
}

.player-points {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a6b3c;
  letter-spacing: 2rpx;
}

.player-points.negative {
  color: #dc2626;
}

/* Action button */
.action-area {
  margin-bottom: 20rpx;
}

.main-action-btn {
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(26,107,60,0.3);
  letter-spacing: 4rpx;
}

.main-action-btn.result {
  background: linear-gradient(135deg, #d97706, #f59e0b);
  box-shadow: 0 4rpx 16rpx rgba(217,119,6,0.3);
}

.main-action-btn:active { opacity: 0.9; }

/* History section */
.section {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.section-title {
  font-size: 22rpx;
  color: #a8a29e;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item {
  display: flex;
  gap: 12rpx;
  align-items: baseline;
  padding: 10rpx 0;
  border-bottom: 2rpx solid #fafaf9;
}

.history-item:last-child { border-bottom: none; }

.hist-round {
  font-size: 22rpx;
  color: #a8a29e;
  white-space: nowrap;
  font-weight: 600;
}

.hist-desc {
  font-size: 26rpx;
  color: #292524;
}

.hist-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hist-sub {
  font-size: 20rpx;
  color: #22884c;
}

/* Modals */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 16rpx 32rpx 48rpx;
  width: 100%;
  max-height: 70vh;
}

.modal-content.tall {
  max-height: 85vh;
}

.modal-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e7e5e4;
  margin: 0 auto 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #292524;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-label {
  font-size: 26rpx;
  color: #57534e;
  display: block;
  margin-bottom: 12rpx;
  margin-top: 16rpx;
  font-weight: 500;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.modal-btn.cancel {
  background: #fafaf9;
  color: #78716c;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

/* Action grid (ron/tsumo/draw) */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 16rpx;
  background: #fdfcfb;
  border-radius: 24rpx;
  border: 3rpx solid #f5f5f4;
}

.action-item:active {
  background: #eefbf2;
  border-color: #4cba78;
}

.action-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon-box.ron {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.action-icon-box.tsumo {
  background: linear-gradient(135deg, #22884c, #14522b);
}

.action-icon-box.draw {
  background: linear-gradient(135deg, #a8a29e, #78716c);
}

.action-icon {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.action-text {
  font-size: 26rpx;
  color: #44403c;
  font-weight: 600;
}

.early-settle {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx;
}

.early-settle-text {
  font-size: 24rpx;
  color: #a8a29e;
  text-decoration: underline;
}

/* Player select */
.player-select {
  display: flex;
  gap: 10rpx;
}

.psel {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  background: #fafaf9;
  font-size: 26rpx;
  color: #44403c;
  font-weight: 500;
  border: 3rpx solid transparent;
}

.psel.active {
  background: #1a6b3c;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

.psel.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.points-input {
  width: 100%;
  padding: 18rpx 24rpx;
  background: #fdfcfb;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  box-sizing: border-box;
  border: 3rpx solid #f5f5f4;
  color: #292524;
}

/* Manual input area */
.manual-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #f5f5f4;
}

.divider-text {
  font-size: 22rpx;
  color: #a8a29e;
  white-space: nowrap;
}

.manual-area {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.manual-area .points-input {
  flex: 1;
  font-size: 28rpx;
}

.manual-confirm-btn {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #14522b, #22884c);
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  font-weight: 600;
}

/* Riichi toggles */
.riichi-info {
  font-size: 22rpx;
  color: #d97706;
}

.riichi-toggle-list {
  display: flex;
  gap: 10rpx;
}

.riichi-toggle-row {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 0;
  background: #fafaf9;
  border-radius: 16rpx;
}

.riichi-toggle-name {
  font-size: 22rpx;
  color: #78716c;
}

.riichi-toggle-check {
  font-size: 22rpx;
  color: #d6d3d1;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.riichi-toggle-check.on {
  background: #d97706;
  color: #fff;
  font-weight: bold;
}

/* Tenpai */
.tenpai-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tenpai-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx;
  background: #fafaf9;
  border-radius: 16rpx;
}

.tenpai-name {
  font-size: 28rpx;
  color: #44403c;
}

.tenpai-check {
  font-size: 24rpx;
  color: #a8a29e;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tenpai-check.on {
  background: #1a6b3c;
  color: #fff;
  font-weight: 600;
}

/* Settlement table */
.result-table {
  margin-bottom: 8rpx;
}

.result-header {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 4rpx solid #f5f5f4;
}

.result-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #fafaf9;
}

.result-row:last-child { border-bottom: none; }

.res-col {
  font-size: 24rpx;
  color: #44403c;
}

.res-col.rank {
  width: 60rpx;
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-weight: bold;
}

.res-col.name { flex: 1; }
.res-col.pts { width: 120rpx; text-align: right; }
.res-col.pt { width: 90rpx; text-align: right; }
.res-col.uma { width: 80rpx; text-align: right; }
.res-col.final { width: 90rpx; text-align: right; }

.result-header .res-col {
  font-size: 22rpx;
  color: #a8a29e;
}

.positive { color: #1a6b3c; }
.negative { color: #dc2626; }
.bold { font-weight: bold; }
