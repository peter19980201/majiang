.container {
  min-height: 100vh;
  background: #f7f5f0;
  padding-bottom: 40rpx;
}

/* Hero section */
.result-hero {
  background: linear-gradient(150deg, #0d3b1f 0%, #1a6b3c 60%, #22884c 100%);
  padding: 48rpx 40rpx 44rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.result-hero::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 60%);
  border-radius: 50%;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 32rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 200rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.badge-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.result-fuban {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
  position: relative;
}

.result-points {
  display: block;
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 96rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
  position: relative;
}

.result-payment {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 4rpx;
  position: relative;
}

/* Hand display */
.result-hand {
  padding: 32rpx 32rpx 0;
}

.hand-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(28,25,23,0.06), 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.hand-tiles-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx;
}

.hand-sep {
  width: 16rpx;
}

.melds-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f5f5f4;
}

.meld-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.meld-tiles-row {
  display: flex;
  gap: 2rpx;
}

.meld-label {
  font-size: 18rpx;
  color: #a8a29e;
  background: #fafaf9;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.context-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.ctx-tag {
  font-size: 22rpx;
  color: #78716c;
  background: #fafaf9;
  padding: 6rpx 16rpx;
  border-radius: 200rpx;
  font-weight: 500;
}

/* Yaku section */
.yaku-section {
  padding: 24rpx 32rpx 0;
}

.yaku-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #44403c;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.yaku-card {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.yaku-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #fafaf9;
}

.yaku-item:last-child {
  border-bottom: none;
}

.yaku-name-col {
  display: flex;
  flex-direction: column;
}

.yaku-cn {
  font-size: 30rpx;
  color: #292524;
  font-weight: 600;
}

.yaku-ja {
  font-size: 22rpx;
  color: #a8a29e;
  margin-top: 4rpx;
}

.yaku-han {
  font-size: 28rpx;
  color: #1a6b3c;
  font-weight: 700;
  white-space: nowrap;
}

.yaku-han.yakuman {
  color: #d97706;
}

/* Fu detail section */
.fu-section {
  padding: 24rpx 32rpx 0;
}

.fu-card {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.fu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.fu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #44403c;
}

.fu-arrow {
  font-size: 24rpx;
  color: #a8a29e;
}

.fu-detail {
  border-top: 2rpx solid #fafaf9;
}

.fu-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #57534e;
}

.fu-row.fu-total {
  background: #fdfcfb;
  font-weight: 600;
  color: #292524;
  border-top: 2rpx solid #f5f5f4;
}

.fu-name {
  font-size: 26rpx;
}

.fu-val {
  font-size: 26rpx;
  color: #44403c;
}

.fu-total .fu-val {
  font-weight: 700;
  font-size: 28rpx;
}

/* Action buttons */
.result-actions {
  display: flex;
  gap: 20rpx;
  padding: 32rpx 32rpx 40rpx;
}

.btn-back {
  flex: 1;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #fafaf9;
  color: #57534e;
}

.btn-back:active {
  background: #f5f5f4;
}

.btn-home {
  flex: 1;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(26,107,60,0.3);
}

.btn-home:active {
  opacity: 0.9;
}
