.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f0efe8;
}

/* 点数头部 */
.score-header {
  background: linear-gradient(135deg, #1a6b3c, #2e7d32);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
  color: #fff;
}

.level {
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 32rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.score-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 16rpx 0;
}

.fu-han {
  font-size: 30rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.total-points {
  font-size: 72rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.payment-desc {
  font-size: 28rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

/* 通用 section */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-header .section-title {
  margin-bottom: 0;
}

.toggle-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 和牌展示 */
.hand-display {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.hand-tiles {
  display: flex;
  gap: 4rpx;
  flex-wrap: wrap;
}

.agari-tile-wrap {
  margin-left: 12rpx;
  position: relative;
}

.melds-display {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meld-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.meld-tiles-row {
  display: flex;
  gap: 2rpx;
}

.meld-label {
  font-size: 18rpx;
  color: #999;
}

.context-info {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.ctx-tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 役种列表 */
.yaku-list {
  display: flex;
  flex-direction: column;
}

.yaku-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.yaku-item:last-child {
  border-bottom: none;
}

.yaku-name {
  display: flex;
  flex-direction: column;
}

.yaku-cn {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.yaku-ja {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.yaku-han {
  font-size: 30rpx;
  color: #1a6b3c;
  font-weight: bold;
}

.yaku-han.yakuman {
  color: #e65100;
}

/* 符数明细 */
.fu-detail {
  margin-top: 16rpx;
}

.fu-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #666;
}

.fu-total {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0 0;
  margin-top: 8rpx;
  border-top: 2rpx solid #e0e0e0;
}

.fu-name {
  font-size: 26rpx;
}

.fu-val {
  font-size: 26rpx;
  color: #333;
}

.fu-val.bold {
  font-weight: bold;
  font-size: 28rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: #1a6b3c;
  color: #fff;
}

.action-btn.primary:active {
  background: #145530;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.secondary:active {
  background: #eee;
}
