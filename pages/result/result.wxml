<view class="container" wx:if="{{result}}">
  <!-- Hero: Points display -->
  <view class="result-hero">
    <view class="hero-badge" wx:if="{{result.level}}">
      <text class="badge-text">{{result.level}}</text>
    </view>
    <text class="result-fuban" wx:if="{{result.han > 0}}">{{result.fu}}符 {{result.han}}番</text>
    <text class="result-points">{{result.payment.total}}点</text>
    <text class="result-payment">{{result.payment.description}}</text>
  </view>

  <!-- Hand display card -->
  <view class="result-hand" wx:if="{{result.input}}">
    <view class="hand-card">
      <view class="hand-tiles-row">
        <!-- Hand tiles -->
        <tile wx:for="{{result.input.hand}}" wx:key="index"
              tid="{{item}}" size="normal"></tile>
        <!-- Separator -->
        <view class="hand-sep"></view>
        <!-- Agari tile -->
        <tile tid="{{result.input.agariTile}}" size="normal" extra="agari"></tile>
      </view>
      <!-- Melds -->
      <view class="melds-row" wx:if="{{result.input.melds.length > 0}}">
        <view class="meld-group" wx:for="{{result.input.melds}}" wx:key="index">
          <view class="meld-tiles-row">
            <tile wx:for="{{item.tiles}}" wx:for-item="t" wx:key="*this"
                  tid="{{t}}" size="small"
                  extra="{{item.type === 'ankan' ? 'dark' : ''}}"></tile>
          </view>
          <text class="meld-label">{{meldTypeNames[item.type]}}</text>
        </view>
      </view>
      <!-- Context tags -->
      <view class="context-tags">
        <text class="ctx-tag">{{windNames[result.input.bakaze]}}场</text>
        <text class="ctx-tag">{{windNames[result.input.jikaze]}}家</text>
        <text class="ctx-tag">{{result.input.agariType === 'tsumo' ? '自摸' : '荣和'}}</text>
      </view>
    </view>
  </view>

  <!-- Yaku list -->
  <view class="yaku-section">
    <text class="yaku-section-title">成立役种</text>
    <view class="yaku-card">
      <view class="yaku-item" wx:for="{{result.yaku}}" wx:key="index">
        <view class="yaku-name-col">
          <text class="yaku-cn">{{item.name}}</text>
          <text class="yaku-ja">{{item.nameJa}}</text>
        </view>
        <text class="yaku-han" wx:if="{{!item.isYakuman}}">{{item.han}}番</text>
        <text class="yaku-han yakuman" wx:elif="{{item.yakumanTimes >= 2}}">双倍役满</text>
        <text class="yaku-han yakuman" wx:else>役满</text>
      </view>
    </view>
  </view>

  <!-- Fu detail (collapsible) -->
  <view class="fu-section" wx:if="{{result.fuDetail && result.fuDetail.length > 0 && result.han > 0}}">
    <view class="fu-card">
      <view class="fu-header" bindtap="toggleFuDetail">
        <text class="fu-title">符数明细</text>
        <text class="fu-arrow">{{showFuDetail ? '▲' : '▼'}}</text>
      </view>
      <view class="fu-detail" wx:if="{{showFuDetail}}">
        <view class="fu-row" wx:for="{{result.fuDetail}}" wx:key="index">
          <text class="fu-name">{{item.name}}</text>
          <text class="fu-val">{{item.fu}}符</text>
        </view>
        <view class="fu-row fu-total">
          <text class="fu-name">合计 (取整)</text>
          <text class="fu-val">{{result.fu}}符</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Action buttons -->
  <view class="result-actions">
    <view class="btn-back" bindtap="goBack">
      <text>返回修改</text>
    </view>
    <view class="btn-home" bindtap="goHome">
      <text>返回首页</text>
    </view>
  </view>
</view>
