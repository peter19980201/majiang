.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  background: #f7f5f0;
}

/* Section cards */
.section {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 24rpx;
  color: #57534e;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.section-header .section-title { margin-bottom: 0; }

.clear-btn {
  font-size: 22rpx;
  color: #dc2626;
  padding: 4rpx 16rpx;
  font-weight: 500;
}

/* Hand tiles display */
.tile-display-area {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  min-height: 90rpx;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx;
  border: 3rpx solid #f5f5f4;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.tile-wrapper {
  display: inline-block;
}

.placeholder {
  color: #d6d3d1;
  font-size: 24rpx;
  padding: 20rpx;
  text-align: center;
  width: 100%;
}

.placeholder.small {
  padding: 10rpx;
  font-size: 22rpx;
}

/* Agari + Meld row */
.row-sections {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.row-sections .section { margin-bottom: 0; }
.flex-1 { flex: 1; }
.flex-2 { flex: 2.5; }

.agari-area {
  min-height: 90rpx;
  justify-content: center;
  border: 3rpx solid #f5f5f4;
  border-radius: 24rpx;
}

.add-meld-btn {
  font-size: 22rpx;
  color: #1a6b3c;
  background: #eefbf2;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.melds-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meld-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.meld-tiles-row {
  display: flex;
  gap: 2rpx;
}

.meld-bottom {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meld-label {
  font-size: 18rpx;
  color: #a8a29e;
  background: #fafaf9;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.meld-del {
  font-size: 24rpx;
  color: #dc2626;
}

/* Tile picker */
.picker-section {
  padding: 20rpx 16rpx;
  border: 3rpx solid #f5f5f4;
}

.target-tabs {
  display: flex;
  gap: 0;
  margin-bottom: 20rpx;
  background: #fafaf9;
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 14rpx 0;
  border-radius: 12rpx;
  color: #78716c;
  font-weight: 500;
  transition: all 0.2s;
}

.tab.active {
  background: #fff;
  color: #1a6b3c;
  font-weight: 600;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
}

.picker-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.picker-row.compact { margin-bottom: 6rpx; }

.jihai-row { justify-content: flex-start; gap: 8rpx; }

.picker-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.picker-tile.disabled { pointer-events: none; }

.picker-tile-sm {
  position: relative;
}

.remain-badge {
  font-size: 16rpx;
  color: #a8a29e;
  margin-top: 2rpx;
  text-align: center;
}

/* Context settings */
.settings-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.setting-item {
  display: flex;
  align-items: center;
}

.setting-label {
  font-size: 26rpx;
  color: #44403c;
  min-width: 80rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.setting-item .seg-ctrl {
  flex: 1;
}

.setting-item .stepper {
  flex: 1;
}

.stepper {
  display: flex;
  align-items: center;
  background: #fafaf9;
  border-radius: 16rpx;
  overflow: hidden;
}

.step-btn {
  width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  color: #78716c;
}

.step-btn:active { background: #f5f5f4; }

.step-val {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  background: #fff;
  height: 56rpx;
  line-height: 56rpx;
}

/* Chip tags */
.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  font-size: 24rpx;
  padding: 12rpx 22rpx;
  border-radius: 200rpx;
  background: #fafaf9;
  color: #78716c;
  border: 3rpx solid transparent;
  transition: all 0.15s;
}

.chip.on {
  background: #fef3c7;
  color: #b45309;
  border-color: #fbbf24;
}

.chip.small {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
}

.chip.on.red {
  background: #fee2e2;
  color: #b91c1c;
  border-color: #ef4444;
}

/* Dora */
.dora-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.dora-row {
  display: flex;
  align-items: center;
}

.dora-label {
  font-size: 24rpx;
  color: #44403c;
  min-width: 100rpx;
  font-weight: 500;
}

.dora-tiles {
  display: flex;
  gap: 8rpx;
  align-items: center;
  flex: 1;
}

.dora-hint {
  font-size: 20rpx;
  color: #a8a29e;
}

.red-toggles {
  display: flex;
  gap: 10rpx;
}

/* Dora inline picker */
.dora-picker {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fdfcfb;
  border-radius: 24rpx;
  border: 2rpx solid #f5f5f4;
}

.dora-picker-hint {
  display: block;
  font-size: 24rpx;
  color: #b45309;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12rpx;
}

.dora-picker-grid {
  padding: 0 4rpx;
}

.dora-picker-cancel {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #a8a29e;
  margin-top: 12rpx;
  padding: 8rpx;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #eefbf2;
  color: #1a6b3c;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* Meld modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 16rpx 32rpx 48rpx;
  width: 100%;
  max-height: 80vh;
}

.modal-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e7e5e4;
  margin: 0 auto 24rpx;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #292524;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #57534e;
  text-align: center;
  display: block;
  margin-bottom: 20rpx;
}

.meld-type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.meld-type-btn {
  background: #fdfcfb;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 3rpx solid #f5f5f4;
}

.meld-type-btn:active {
  background: #eefbf2;
  border-color: #4cba78;
}

.meld-type-icon {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a6b3c;
}

.meld-type-desc {
  font-size: 20rpx;
  color: #a8a29e;
}

.editing-meld-display {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  min-height: 90rpx;
  align-items: center;
}

.modal-picker {
  padding: 0 8rpx;
}

.modal-actions {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.modal-btn {
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 16rpx;
}

.modal-btn.cancel {
  background: #fafaf9;
  color: #78716c;
}

/* Board mode context bar */
.board-context {
  padding: 16rpx 24rpx;
}

.bc-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.bc-tag {
  font-size: 24rpx;
  color: #fff;
  background: #1a6b3c;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

/* Board result modal */
.board-result {
  max-height: 80vh;
}

.br-score-section {
  text-align: center;
  padding: 16rpx 0 24rpx;
  border-bottom: 2rpx solid #f5f5f4;
  margin-bottom: 16rpx;
}

.br-level {
  display: block;
  font-size: 28rpx;
  color: #d97706;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.br-score-line {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 16rpx;
}

.br-fuhan {
  font-size: 26rpx;
  color: #78716c;
}

.br-total {
  font-family: 'Songti SC', 'STSong', 'Noto Serif CJK SC', serif;
  font-size: 56rpx;
  font-weight: bold;
  color: #1a6b3c;
}

.br-payment {
  display: block;
  font-size: 24rpx;
  color: #a8a29e;
  margin-top: 8rpx;
}

.br-sticks {
  display: block;
  font-size: 24rpx;
  color: #d97706;
  font-weight: bold;
  margin-top: 8rpx;
}

.br-yaku-list {
  max-height: 240rpx;
  margin-bottom: 20rpx;
}

.br-yaku-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 8rpx;
  border-bottom: 2rpx solid #fafaf9;
}

.br-yaku-item:last-child {
  border-bottom: none;
}

.br-yaku-name {
  font-size: 26rpx;
  color: #292524;
}

.br-yaku-han {
  font-size: 26rpx;
  color: #1a6b3c;
  font-weight: bold;
}

.br-yaku-han.yakuman {
  color: #d97706;
}

.br-actions {
  display: flex;
  gap: 16rpx;
}

.br-actions .modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-weight: bold;
}

.br-actions .modal-btn.confirm {
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(26,107,60,0.3);
}

/* Calculate button - floating rounded */
.calc-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #14522b, #22884c);
  color: #fff;
  text-align: center;
  line-height: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  z-index: 100;
  letter-spacing: 8rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(26,107,60,0.35);
}

.calc-btn:active { opacity: 0.9; }
