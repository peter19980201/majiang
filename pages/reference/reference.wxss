.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f5f0;
}

/* Search bar */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
  border: 3rpx solid #f5f5f4;
  transition: all 0.2s;
}

.search-icon {
  font-size: 28rpx;
  color: #d6d3d1;
  margin-right: 12rpx;
  font-weight: bold;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  color: #292524;
}

.search-clear {
  font-size: 28rpx;
  color: #a8a29e;
  padding: 8rpx;
}

/* Filter tags */
.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cat-scroll {
  flex: 1;
  white-space: nowrap;
}

.cat-tags {
  display: inline-flex;
  gap: 10rpx;
}

.cat-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 200rpx;
  background: #fff;
  color: #78716c;
  white-space: nowrap;
  font-weight: 500;
  border: 2rpx solid #f5f5f4;
}

.cat-tag.active {
  background: #1a6b3c;
  color: #fff;
  border-color: #1a6b3c;
}

.menzen-toggle {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 200rpx;
  background: #fff;
  color: #78716c;
  white-space: nowrap;
  flex-shrink: 0;
  font-weight: 500;
  border: 2rpx solid #f5f5f4;
}

.menzen-toggle.active {
  background: #d97706;
  color: #fff;
  border-color: #d97706;
}

/* Yaku cards */
.yaku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.yaku-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 1rpx 2rpx rgba(28,25,23,0.04);
  border: 2rpx solid #fafaf9;
}

.yaku-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.yaku-title-area {
  display: flex;
  flex-direction: column;
}

.yaku-name-cn {
  font-size: 30rpx;
  font-weight: 600;
  color: #292524;
}

.yaku-name-ja {
  font-size: 22rpx;
  color: #a8a29e;
  margin-top: 2rpx;
}

.yaku-badges {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 200rpx;
  white-space: nowrap;
  font-weight: 600;
}

.badge.han {
  background: #dcf5e5;
  color: #1a6b3c;
}

.badge.han.open {
  background: #f3e5f5;
  color: #7b1fa2;
}

.badge.menzen {
  background: #e3f2fd;
  color: #1565c0;
}

.badge.yakuman {
  background: #fef3c7;
  color: #b45309;
}

.badge.yakuman.double {
  background: #fee2e2;
  color: #b91c1c;
}

.yaku-desc {
  font-size: 24rpx;
  color: #a8a29e;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

/* Expanded detail */
.yaku-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #fafaf9;
  background: #fdfcfb;
  margin: 16rpx -28rpx 0;
  padding: 20rpx 28rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.detail-section {
  margin-bottom: 16rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 22rpx;
  color: #a8a29e;
  display: block;
  margin-bottom: 6rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #57534e;
  line-height: 1.6;
  display: block;
}

.example-hand {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.example-tiles {
  display: flex;
  gap: 3rpx;
  flex-wrap: wrap;
}

.example-agari {
  margin-left: 10rpx;
}

.example-note {
  font-size: 22rpx;
  color: #a8a29e;
  margin-top: 8rpx;
  display: block;
}

/* Empty state */
.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #d6d3d1;
}
