.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f0efe8;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
  font-weight: bold;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 筛选标签 */
.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.cat-scroll {
  flex: 1;
  white-space: nowrap;
}

.cat-tags {
  display: inline-flex;
  gap: 8rpx;
}

.cat-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #fff;
  color: #666;
  white-space: nowrap;
}

.cat-tag.active {
  background: #1a6b3c;
  color: #fff;
}

.menzen-toggle {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #fff;
  color: #666;
  white-space: nowrap;
  flex-shrink: 0;
}

.menzen-toggle.active {
  background: #e65100;
  color: #fff;
}

/* 役种卡片 */
.yaku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.yaku-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.yaku-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.yaku-title-area {
  display: flex;
  flex-direction: column;
}

.yaku-name-cn {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.yaku-name-ja {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.yaku-badges {
  display: flex;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.badge.han {
  background: #e8f5e9;
  color: #1a6b3c;
  font-weight: bold;
}

.badge.han.open {
  background: #f3e5f5;
  color: #7b1fa2;
}

.badge.menzen {
  background: #e3f2fd;
  color: #1565c0;
}

.badge.yakuman {
  background: #fff3e0;
  color: #e65100;
  font-weight: bold;
}

.badge.yakuman.double {
  background: #fce4ec;
  color: #c62828;
}

.yaku-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  display: block;
}

/* 展开详情 */
.yaku-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-section {
  margin-bottom: 16rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.example-hand {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.example-tiles {
  display: flex;
  gap: 3rpx;
  flex-wrap: wrap;
}

.example-agari {
  margin-left: 10rpx;
}

.example-note {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}
